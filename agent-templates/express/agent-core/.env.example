# Copy to .env and fill in. Used by `npm run agent -- "your query"`.
# .env is gitignored.

# Your dtc-research MCP server (Streamable HTTP /mcp or legacy /sse).
# Transport auto-detects; set MCP_TRANSPORT=http or sse to force one.
MCP_URL=http://dtcserver:3100/mcp

# Your local OpenAI-compatible model endpoint + model id.
# MODEL_ID can be any model your endpoint serves that supports OpenAI-style tool calling.
# gemma4:12b-web is a custom local Ollama build (FROM gemma4:12b-tools, num_ctx 32768,
# temperature 0.2) — swap in whatever tool-capable model you run.
OPENAI_BASE_URL=http://dtcserver:1234/v1
MODEL_ID=gemma4:12b-web
OPENAI_API_KEY=sk-local
